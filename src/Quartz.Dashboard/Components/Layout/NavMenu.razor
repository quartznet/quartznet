@code
{
    private string _currentUri = string.Empty;

    protected override void OnInitialized()
    {
        _currentUri = NavigationManager.Uri;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private string NavClass(string route)
    {
        string relativePath = NavigationManager.ToBaseRelativePath(_currentUri);

        // Normalize: strip trailing slash, ensure leading slash
        if (!relativePath.StartsWith('/'))
        {
            relativePath = "/" + relativePath;
        }

        relativePath = relativePath.TrimEnd('/');
        string normalizedRoute = route.TrimEnd('/');

        // Exact match for dashboard root, prefix match for sub-pages
        if (normalizedRoute == "/quartz")
        {
            return relativePath == "/quartz" ? "qz-nav-active" : string.Empty;
        }

        bool isActive = relativePath.Equals(normalizedRoute, StringComparison.OrdinalIgnoreCase)
            || relativePath.StartsWith(normalizedRoute + "/", StringComparison.OrdinalIgnoreCase);

        return isActive ? "qz-nav-active" : string.Empty;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUri = e.Location;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
